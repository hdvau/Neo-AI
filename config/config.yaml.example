# Operation Mode
mode: "digital_ocean"                                     # Options: 'lm_studio' or 'digital_ocean'

# Lm studio Configuration
  api_url: "http:127.0.0.1:1234/v1"     # Default localhost url, diplayed unter the LM Studio Server Tab
  api_key: ""                                    # Default API key for LM Studio
  model: "lmstudio-community/Meta-Llama-3.1-8B-Instruct-GGUF/Meta-Llama-3.1-8B-Instruct-Q4_K_M.gguf"   # Found in LM Studio -> Server -> your loaded Model. Keep in mind to change this, if you switch the modell. And use the pre prompt as System Promt for the model

# DigitalOcean Configuration
digital_ocean:
  agent_id: "your-agent-id"                          # DigitalOcean agent ID
  agent_key: "your-agent-key"                        # Authentication key
  agent_endpoint: "https://your-endpoint.app/api/v1"  # API endpoint
  model: "model-name"                                # Model to use

# Security Settings
security:
  auto_approve_commands: false                        # Automatic command approval
  require_approval: true                              # Manual approval requirement

# LM Studio Configuration (Do not modify unless necessary)
lm_studio:
  antiprompt: ""
  prompts:
    prefix: "### Instruction:"
    suffix: "### Response:"
