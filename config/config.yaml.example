# Neo-AI Configuration Example
# Copy this file to config/config.yaml and fill in your values.
# NEVER commit config.yaml — it contains credentials.

# Operation mode — choose one: "ollama" | "lm_studio" | "claude"
mode: "ollama"

# ── Ollama (local, no API key required) ──────────────────────────────────────
# Install: https://ollama.com  |  Pull a model: ollama pull llama3.2
# List available models: ollama list
ollama_config:
  api_url: "http://localhost:11434/v1"   # Ollama's OpenAI-compatible endpoint
  model: "llama3.2"                       # Change to any model you have pulled

# ── LM Studio (local, no API key required) ───────────────────────────────────
lm_studio_config:
  api_url: "http://127.0.0.1:1234/v1"
  api_key: ""
  model: "lmstudio-community/Meta-Llama-3.1-8B-Instruct-GGUF/Meta-Llama-3.1-8B-Instruct-Q4_K_M.gguf"
  input_prefix: "### Instruction:"       # Optional — leave empty for most models
  input_suffix: "### Response:"

# ── OpenAI (cloud) ────────────────────────────────────────────────────────────
# Get your API key at: https://platform.openai.com
# The key can also be set via the OPENAI_API_KEY environment variable.
openai_config:
  api_key: "sk-..."            # or leave empty and export OPENAI_API_KEY
  model: "gpt-4o"              # other options: gpt-4-turbo, gpt-3.5-turbo, o1
  api_url: "https://api.openai.com/v1"  # override for Azure OpenAI or compatible APIs

# ── Anthropic Claude (cloud) ──────────────────────────────────────────────────
# Get your API key at: https://console.anthropic.com
# The key can also be set via the ANTHROPIC_API_KEY environment variable
# instead of storing it in this file.
claude_config:
  api_key: "sk-ant-..."          # or leave empty and export ANTHROPIC_API_KEY
  model: "claude-opus-4-5"       # other options: claude-3-5-sonnet-20241022
  max_tokens: 4096

# ── Command Approval ──────────────────────────────────────────────────────────
command_approval:
  require_approval: true        # Prompt before executing any command
  auto_approve_all: false       # DANGER: skips approval for every command

# ── Streaming ────────────────────────────────────────────────────────────────
stream: true

# ── History ──────────────────────────────────────────────────────────────────
max_history_messages: 40

# ── Command execution ─────────────────────────────────────────────────────────
# Timeout in seconds per command. Increase for long-running tasks.
command_timeout: 120
